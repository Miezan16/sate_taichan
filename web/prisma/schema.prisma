// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS (Pilihan Terbatas)
// ==========================================

enum Role {
  admin
  kasir
}

enum StatusPesanan {
  PENDING    // Kolom 1: Pesanan Masuk (Baru)
  PROCESSING // Kolom 2: Sedang Dipanggang (Proses)
  UNPAID     // Kolom 3: Selesai Dipanggang / Menunggu Pembayaran
  COMPLETED  // Masuk ke Riwayat Transaksi
}

enum MetodePembayaran {
  CASH
  EWALLET
}

// ==========================================
// 2. MODELS (Tabel Database)
// ==========================================

model User {
  id            Int         @id @default(autoincrement())
  username      String      @unique
  password_hash String
  role          Role        @default(kasir)
  transaksi     Transaksi[] 
}

model Menu {
  id              Int             @id @default(autoincrement())
  nama            String
  deskripsi       String?
  kategori        String          @default("Sate") // Tambahkan ini
  image           String?         // Tambahkan ini untuk foto
  protein         String          @default("Ayam")
  harga           Int
  stok            Int             @default(100) 
  level_pedas_min Int             @default(0)
  level_pedas_max Int             @default(5)
  kalori          Int             @default(0)   
  favorit         Boolean         @default(false)
  tersedia        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  
  TransaksiItem   TransaksiItem[] 
}

model Transaksi {
  id                Int               @id @default(autoincrement())
  kasir_id          Int?              // Opsional, ID User penginput
  kasir_nama        String?           // Nama Kasir yang muncul di struk (Manual Input/Auto)
  nama_pelanggan    String            
  nomor_meja        String            
  status            StatusPesanan     @default(PENDING) 
  metode_pembayaran MetodePembayaran? 
  total_harga       Int
  uang_bayar        Int?              // Uang yang diterima dari pelanggan
  kembalian         Int?              // Selisih bayar
  tanggal           DateTime          @default(now())
  updatedAt         DateTime          @updatedAt // Penting untuk tracking perpindahan status
  
  // Relasi
  kasir             User?             @relation(fields: [kasir_id], references: [id])
  items             TransaksiItem[]
}

model TransaksiItem {
  id           Int       @id @default(autoincrement())
  transaksi_id Int
  menu_id      Int
  jumlah       Int
  harga_satuan Int
  
  // Relasi
  transaksi    Transaksi @relation(fields: [transaksi_id], references: [id], onDelete: Cascade)
  menu         Menu      @relation(fields: [menu_id], references: [id])
}

model Cabang {
  id          Int      @id @default(autoincrement())
  nama_cabang String
  alamat      String
  link_maps   String?
  telepon     String?
}