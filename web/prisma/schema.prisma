// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. ENUMS (Pilihan Terbatas)
// ==========================================

enum Role {
  admin
  kasir
}

enum StatusPesanan {
  PENDING 
  PROCESSING 
  UNPAID 
  COMPLETED 
}

enum MetodePembayaran {
  CASH
  EWALLET
}

// ==========================================
// 2. MODELS (Tabel Database)
// ==========================================

model User {
  id            Int           @id @default(autoincrement())
  username      String        @unique
  password_hash String
  role          Role          @default(kasir)
  cabang_id     Int? 
  transaksi     Transaksi[]
  activityLogs  ActivityLog[]

  cabang Cabang? @relation(fields: [cabang_id], references: [id])
}

model Menu {
  id                  Int       @id @default(autoincrement())
  nama                String
  deskripsi           String?
  kategori            String    @default("Sate")
  image               String?
  protein             String    @default("Ayam")
  harga               Int
  stok                Int       @default(100)
  low_stock_threshold Int       @default(10) 
  level_pedas_min     Int       @default(0)
  level_pedas_max     Int       @default(5)
  kalori              Int       @default(0)
  favorit             Boolean   @default(false)
  tersedia            Boolean   @default(true)
  deleted_at          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  TransaksiItem TransaksiItem[]
}

model Transaksi {
  id                Int               @id @default(autoincrement())
  kasir_id          Int?
  kasir_nama        String?
  cabang_id         Int?              // <-- DITAMBAHKAN: Relasi ke cabang
  nama_pelanggan    String
  nomor_meja        String
  status            StatusPesanan     @default(PENDING)
  metode_pembayaran MetodePembayaran?
  total_harga       Int
  uang_bayar        Int?
  kembalian         Int?
  tanggal           DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  kasir  User?   @relation(fields: [kasir_id], references: [id])
  cabang Cabang? @relation(fields: [cabang_id], references: [id]) // <-- DITAMBAHKAN
  items  TransaksiItem[]
}

model TransaksiItem {
  id           Int @id @default(autoincrement())
  transaksi_id Int
  menu_id      Int
  jumlah       Int
  harga_satuan Int

  transaksi Transaksi @relation(fields: [transaksi_id], references: [id], onDelete: Cascade)
  menu      Menu      @relation(fields: [menu_id], references: [id])
}

model Cabang {
  id          Int     @id @default(autoincrement())
  nama_cabang String
  alamat      String
  link_maps   String?
  telepon     String?
  users       User[] 
  transaksi   Transaksi[] // <-- DITAMBAHKAN: Relasi balik dari Transaksi
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String 
  entity     String 
  entity_id  Int 
  old_value  String?
  new_value  String? 
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)
}